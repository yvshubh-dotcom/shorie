# ================================
# Shortie - Environment Variables
# ================================

# MongoDB Connection URI (MongoDB Atlas recommended)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/shortie?retryWrites=true&w=majority

# Session Secret (use a long random string in production)
SESSION_SECRET=change-this-to-a-very-long-random-secret-string-in-production

# Port (optional, defaults to 3000)
PORT=3000

# Site URL (optional, used for generating short links)
SITE_URL=https://your-domain.com
