<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="min-h-screen flex items-center justify-center px-4 pt-16 pb-16">
  <div class="w-full max-w-sm fade-up">

    <!-- Header -->
    <div class="text-center mb-8">
      <div class="inline-flex w-12 h-12 rounded-2xl btn-primary items-center justify-center mb-4 shadow-lg">
        <i data-lucide="lock" class="w-5 h-5 text-white"></i>
      </div>
      <h1 class="font-display text-2xl font-bold text-white mb-1">Welcome back</h1>
      <p class="text-slate-500 text-sm">Sign in to your Shortie account</p>
    </div>

    <!-- Card -->
    <div class="glass rounded-2xl p-6 shadow-2xl">

      <!-- Error message -->
      <% if (error) { %>
      <div class="flex items-start gap-3 p-3 rounded-xl bg-red-500/10 border border-red-500/20 mb-5">
        <i data-lucide="alert-circle" class="w-4 h-4 text-red-400 mt-0.5 flex-shrink-0"></i>
        <p class="text-red-400 text-sm"><%= error %></p>
      </div>
      <% } %>

      <form action="/login" method="POST" id="loginForm" novalidate>

        <!-- Email -->
        <div class="mb-4">
          <label class="block text-xs font-medium text-slate-400 mb-1.5 uppercase tracking-wider">
            Email address
          </label>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="you@example.com"
            class="input-dark w-full rounded-xl px-4 py-3 text-sm"
          />
        </div>

        <!-- Password -->
        <div class="mb-6">
          <label class="block text-xs font-medium text-slate-400 mb-1.5 uppercase tracking-wider">
            Password
          </label>
          <div class="relative">
            <input
              type="password"
              name="password"
              id="passwordInput"
              required
              autocomplete="current-password"
              placeholder="••••••••"
              class="input-dark w-full rounded-xl px-4 py-3 pr-11 text-sm"
            />
            <button type="button" onclick="togglePassword()"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-300 transition-colors">
              <i data-lucide="eye" class="w-4 h-4" id="eyeIcon"></i>
            </button>
          </div>
        </div>

        <!-- Submit -->
        <button type="submit"
                class="btn-primary w-full py-3 rounded-xl text-white font-semibold text-sm tracking-wide">
          Sign In
        </button>

      </form>

    </div>

    <!-- Footer link -->
    <p class="text-center text-slate-500 text-sm mt-5">
      Don't have an account?
      <a href="/signup" class="text-blue-400 hover:text-blue-300 font-medium transition-colors ml-1">
        Sign up free →
      </a>
    </p>

  </div>
</main>

<%- include('partials/footer') %>

<script>
function togglePassword() {
  const inp  = document.getElementById('passwordInput');
  const icon = document.getElementById('eyeIcon');
  if (inp.type === 'password') {
    inp.type = 'text';
    icon.setAttribute('data-lucide', 'eye-off');
  } else {
    inp.type = 'password';
    icon.setAttribute('data-lucide', 'eye');
  }
  lucide.createIcons();
}
</script>
