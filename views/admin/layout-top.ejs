<%- include('../partials/header') %>
<div class="flex min-h-screen">
  <!-- Admin Sidebar -->
  <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-64 glass border-r border-white/5 flex flex-col transition-transform duration-300 ease-in-out -translate-x-full lg:translate-x-0">
    <div class="flex items-center gap-3 px-6 py-5 border-b border-white/5">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-yellow-400 to-orange-500 flex items-center justify-center font-bold text-white text-lg">A</div>
      <span class="font-bold text-lg">Admin Panel</span>
      <button onclick="closeSidebar()" class="ml-auto lg:hidden text-gray-500 hover:text-white">✕</button>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-1">
      <% const adminNav = [
        { href: '/admin', label: 'Overview', icon: '⊞' },
        { href: '/admin/users', label: 'Users', icon: '👤' },
        { href: '/admin/links', label: 'Links', icon: '⛓' },
        { href: '/admin/withdrawals', label: 'Withdrawals', icon: '↑' },
      ] %>
      <% adminNav.forEach(item => { %>
      <a href="<%= item.href %>"
         class="sidebar-link flex items-center gap-3 px-4 py-2.5 text-sm text-gray-400 font-medium <%= currentPath === item.href ? 'active' : '' %>">
        <span class="w-5 text-center"><%= item.icon %></span><%= item.label %>
      </a>
      <% }) %>

      <div class="pt-2 mt-2 border-t border-white/5">
        <a href="/dashboard" class="sidebar-link flex items-center gap-3 px-4 py-2.5 text-sm text-brand-400 font-medium">
          <span class="w-5 text-center">←</span> Back to Dashboard
        </a>
        <a href="/auth/logout" class="sidebar-link flex items-center gap-3 px-4 py-2.5 text-sm text-red-400 font-medium">
          <span class="w-5 text-center">→</span> Logout
        </a>
      </div>
    </nav>
  </aside>
  <div id="sidebar-overlay" onclick="closeSidebar()" class="fixed inset-0 bg-black/60 z-30 hidden lg:hidden"></div>

  <div class="flex-1 lg:ml-64 flex flex-col">
    <header class="lg:ml-0 sticky top-0 z-20 glass border-b border-white/5">
      <div class="flex items-center gap-4 px-4 sm:px-6 h-14">
        <button onclick="openSidebar()" class="lg:hidden p-2 text-gray-400 hover:text-white rounded-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <h1 class="text-sm font-semibold text-yellow-400">★ Admin Panel</h1>
        <span class="ml-auto text-xs text-gray-600"><%= user.username %></span>
      </div>
    </header>
