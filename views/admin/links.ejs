<%- include('layout-top') %>

    <main class="flex-1 p-4 sm:p-6 animate-fade-up space-y-5">
      <h2 class="text-xl font-bold">All Links <span class="text-gray-500 text-base font-normal">(<%= total %>)</span></h2>

      <div class="glass rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/5">
                <th class="text-left px-5 py-3 text-xs text-gray-500">Short Code</th>
                <th class="text-left px-4 py-3 text-xs text-gray-500">Owner</th>
                <th class="text-left px-4 py-3 text-xs text-gray-500">Destination</th>
                <th class="text-right px-4 py-3 text-xs text-gray-500">Clicks</th>
                <th class="text-right px-4 py-3 text-xs text-gray-500">Earnings</th>
                <th class="text-right px-4 py-3 text-xs text-gray-500">Created</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <% links.forEach(link => { %>
              <tr class="hover:bg-white/2 transition-colors">
                <td class="px-5 py-3.5">
                  <span class="font-mono text-brand-300 text-xs">/r/<%= link.shortCode %></span>
                </td>
                <td class="px-4 py-3.5 text-xs text-gray-400"><%= link.userId ? link.userId.username : 'Unknown' %></td>
                <td class="px-4 py-3.5">
                  <p class="text-gray-400 text-xs truncate max-w-xs"><%= link.originalUrl %></p>
                </td>
                <td class="px-4 py-3.5 text-right font-semibold"><%= link.clicks.toLocaleString() %></td>
                <td class="px-4 py-3.5 text-right text-brand-400 font-mono text-xs">$<%= link.earnings.toFixed(4) %></td>
                <td class="px-4 py-3.5 text-right text-gray-600 text-xs"><%= new Date(link.createdAt).toLocaleDateString() %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <% if (totalPages > 1) { %>
      <div class="flex items-center justify-center gap-2">
        <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="/admin/links?page=<%= i %>"
           class="w-9 h-9 rounded-lg flex items-center justify-center text-sm <%= i === page ? 'bg-brand-500 text-white' : 'glass text-gray-400 glass-hover' %>"><%= i %></a>
        <% } %>
      </div>
      <% } %>
    </main>

<%- include('layout-bottom') %>
