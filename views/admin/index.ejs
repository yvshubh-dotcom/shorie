<%- include('layout-top') %>

    <main class="flex-1 p-4 sm:p-6 animate-fade-up space-y-6">
      <h2 class="text-xl font-bold">Platform Overview</h2>

      <% if (success) { %><div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-xl px-4 py-3">✓ <%= success %></div><% } %>
      <% if (error) { %><div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-xl px-4 py-3">✕ <%= error %></div><% } %>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        <%
          const adminCards = [
            { label: 'Total Users', value: stats.totalUsers.toLocaleString(), color: 'text-blue-400' },
            { label: 'Total Links', value: stats.totalLinks.toLocaleString(), color: 'text-brand-400' },
            { label: 'Total Clicks', value: stats.totalClicks.toLocaleString(), color: 'text-purple-400' },
            { label: 'Paid Out', value: '$' + stats.totalEarningsPaid.toFixed(2), color: 'text-orange-400' },
            { label: 'Pending Withdrawals', value: stats.pendingWithdrawals.toString(), color: 'text-yellow-400' },
          ]
        %>
        <% adminCards.forEach(c => { %>
        <div class="glass rounded-2xl p-4">
          <p class="<%= c.color %> text-2xl font-bold mb-1"><%= c.value %></p>
          <p class="text-xs text-gray-500"><%= c.label %></p>
        </div>
        <% }) %>
      </div>

      <!-- Settings -->
      <div class="glass card-glow rounded-2xl p-6">
        <h3 class="font-semibold mb-5">Platform Settings</h3>
        <form action="/admin/settings" method="POST" class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Global CPM Rate ($/1000 clicks)</label>
            <input type="number" name="cpmRate" value="<%= cpmRate %>" step="0.01" min="0" required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500/60 focus:ring-1 focus:ring-brand-500/30 transition-all"/>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-400 mb-1.5">Minimum Withdrawal ($)</label>
            <input type="number" name="minWithdraw" value="<%= minWithdraw %>" step="0.01" min="0" required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-brand-500/60 focus:ring-1 focus:ring-brand-500/30 transition-all"/>
          </div>
          <div class="sm:col-span-2">
            <button type="submit" class="bg-brand-500 hover:bg-brand-400 text-white font-semibold px-6 py-3 rounded-xl transition-all hover:scale-105 text-sm">
              Save Settings
            </button>
          </div>
        </form>
      </div>

      <!-- Quick links -->
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/admin/users" class="glass rounded-2xl p-5 text-center hover:border-blue-500/30 transition-all">
          <p class="text-3xl mb-2">👤</p>
          <p class="font-semibold text-sm">Manage Users</p>
          <p class="text-xs text-gray-500 mt-1"><%= stats.totalUsers %> users</p>
        </a>
        <a href="/admin/links" class="glass rounded-2xl p-5 text-center hover:border-brand-500/30 transition-all">
          <p class="text-3xl mb-2">⛓</p>
          <p class="font-semibold text-sm">Manage Links</p>
          <p class="text-xs text-gray-500 mt-1"><%= stats.totalLinks %> links</p>
        </a>
        <a href="/admin/withdrawals" class="glass rounded-2xl p-5 text-center hover:border-yellow-500/30 transition-all">
          <p class="text-3xl mb-2">↑</p>
          <p class="font-semibold text-sm">Withdrawals</p>
          <p class="text-xs text-gray-500 mt-1"><%= stats.pendingWithdrawals %> pending</p>
        </a>
      </div>
    </main>

<%- include('layout-bottom') %>
