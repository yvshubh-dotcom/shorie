<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="min-h-screen px-4 pt-24 pb-16">
  <div class="max-w-4xl mx-auto">

    <!-- Page Header -->
    <div class="mb-8 fade-up">
      <h1 class="font-display text-3xl font-bold text-white mb-1">Dashboard</h1>
      <p class="text-slate-500 text-sm">
        Welcome back, <span class="text-slate-300"><%= userEmail %></span>
      </p>
    </div>

    <!-- Stats cards -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-8 fade-up-delay">

      <!-- Total Links -->
      <div class="glass rounded-2xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center"
               style="background: rgba(59,130,246,0.15);">
            <i data-lucide="link" class="w-4 h-4 text-blue-400"></i>
          </div>
          <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Total Links</span>
        </div>
        <p class="font-display text-3xl font-bold text-white"><%= totalLinks %></p>
      </div>

      <!-- Total Clicks -->
      <div class="glass rounded-2xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center"
               style="background: rgba(139,92,246,0.15);">
            <i data-lucide="mouse-pointer-click" class="w-4 h-4 text-purple-400"></i>
          </div>
          <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Total Clicks</span>
        </div>
        <p class="font-display text-3xl font-bold text-white"><%= totalClicks %></p>
      </div>

      <!-- Quick create -->
      <div class="col-span-2 sm:col-span-1 glass rounded-2xl p-5 flex flex-col justify-between">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-xl flex items-center justify-center"
               style="background: rgba(34,197,94,0.15);">
            <i data-lucide="plus" class="w-4 h-4 text-green-400"></i>
          </div>
          <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">New Link</span>
        </div>
        <a href="/"
           class="btn-primary text-center text-white text-sm font-semibold py-2 rounded-xl">
          Create Short Link
        </a>
      </div>

    </div>

    <!-- Error -->
    <% if (error) { %>
    <div class="flex items-start gap-3 p-3 rounded-xl bg-red-500/10 border border-red-500/20 mb-6">
      <i data-lucide="alert-circle" class="w-4 h-4 text-red-400 mt-0.5"></i>
      <p class="text-red-400 text-sm"><%= error %></p>
    </div>
    <% } %>

    <!-- Links Table -->
    <div class="glass rounded-2xl overflow-hidden fade-up-delay-2">

      <div class="px-6 py-4 border-b border-white/5 flex items-center justify-between">
        <h2 class="font-display text-base font-semibold text-white flex items-center gap-2">
          <i data-lucide="table-2" class="w-4 h-4 text-slate-400"></i>
          Your Links
        </h2>
        <span class="text-xs text-slate-500"><%= totalLinks %> total</span>
      </div>

      <% if (links.length === 0) { %>
        <!-- Empty state -->
        <div class="flex flex-col items-center justify-center py-16 px-4 text-center">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-4"
               style="background: rgba(148,163,184,0.07);">
            <i data-lucide="link-2-off" class="w-6 h-6 text-slate-600"></i>
          </div>
          <p class="font-medium text-slate-400 mb-1">No links yet</p>
          <p class="text-slate-600 text-sm mb-5">Create your first short link to get started.</p>
          <a href="/" class="btn-primary text-white text-sm font-semibold px-5 py-2.5 rounded-xl">
            Create Link →
          </a>
        </div>
      <% } else { %>

        <!-- Table (desktop) -->
        <div class="hidden sm:block overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-white/5">
                <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider px-6 py-3">Short Link</th>
                <th class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider px-6 py-3">Original URL</th>
                <th class="text-center text-xs font-medium text-slate-500 uppercase tracking-wider px-6 py-3">Clicks</th>
                <th class="text-right text-xs font-medium text-slate-500 uppercase tracking-wider px-6 py-3">Created</th>
              </tr>
            </thead>
            <tbody>
              <% links.forEach(link => { %>
              <% const shortUrl = protocol + '://' + host + '/l/' + link.slug; %>
              <tr class="table-row border-b border-white/[0.04] last:border-0">
                <!-- Short URL -->
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <span class="text-blue-400 font-medium font-mono text-xs"><%= link.slug %></span>
                    <button onclick="copyToClipboard('<%= shortUrl %>', this)"
                            class="text-slate-600 hover:text-slate-300 transition-colors p-1 rounded-md hover:bg-white/5">
                      <i data-lucide="copy" class="w-3 h-3"></i>
                    </button>
                  </div>
                </td>
                <!-- Original URL -->
                <td class="px-6 py-4">
                  <a href="<%= link.original_url %>" target="_blank" rel="noopener noreferrer"
                     class="text-slate-400 hover:text-white transition-colors text-xs truncate max-w-xs inline-block"
                     title="<%= link.original_url %>">
                    <%= link.original_url.replace(/^https?:\/\//, '').substring(0, 50) %><%= link.original_url.length > 60 ? '…' : '' %>
                  </a>
                </td>
                <!-- Clicks -->
                <td class="px-6 py-4 text-center">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium
                               <%= link.clicks > 0 ? 'bg-purple-500/15 text-purple-300' : 'bg-slate-800 text-slate-500' %>">
                    <i data-lucide="mouse-pointer-click" class="w-3 h-3"></i>
                    <%= link.clicks %>
                  </span>
                </td>
                <!-- Date -->
                <td class="px-6 py-4 text-right">
                  <span class="text-xs text-slate-600">
                    <%= new Date(link.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %>
                  </span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Cards (mobile) -->
        <div class="sm:hidden divide-y divide-white/5">
          <% links.forEach(link => { %>
          <% const shortUrl = protocol + '://' + host + '/l/' + link.slug; %>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between mb-2">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-blue-400 font-mono text-xs font-medium"><%= link.slug %></span>
                  <button onclick="copyToClipboard('<%= shortUrl %>', this)"
                          class="text-slate-600 hover:text-slate-300 transition-colors">
                    <i data-lucide="copy" class="w-3 h-3"></i>
                  </button>
                </div>
                <p class="text-slate-500 text-xs truncate max-w-[220px]">
                  <%= link.original_url.replace(/^https?:\/\//, '').substring(0, 40) %>…
                </p>
              </div>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium
                           <%= link.clicks > 0 ? 'bg-purple-500/15 text-purple-300' : 'bg-slate-800 text-slate-500' %>">
                <%= link.clicks %> clicks
              </span>
            </div>
            <p class="text-slate-700 text-xs">
              <%= new Date(link.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %>
            </p>
          </div>
          <% }) %>
        </div>

      <% } %>
    </div>

  </div>
</main>

<%- include('partials/footer') %>

<script>
async function copyToClipboard(text, btn) {
  try {
    await navigator.clipboard.writeText(text);
    const icon = btn.querySelector('i');
    icon.setAttribute('data-lucide', 'check');
    lucide.createIcons();
    setTimeout(() => {
      icon.setAttribute('data-lucide', 'copy');
      lucide.createIcons();
    }, 1800);
  } catch (e) {
    const ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
  }
}
</script>
