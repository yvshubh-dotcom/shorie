<%- include('partials/head') %>
<%- include('partials/navbar') %>

<main class="min-h-screen flex flex-col items-center justify-center px-4 pt-20 pb-16">

  <!-- Hero section -->
  <div class="w-full max-w-xl text-center mb-10 fade-up">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6
                text-xs font-medium text-blue-300 border border-blue-500/20 bg-blue-500/10">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
      Link shortener + monetization
    </div>

    <h1 class="font-display text-5xl sm:text-6xl font-extrabold text-white leading-tight mb-4 logo-glow">
      Shorten.<br/>
      <span style="background: linear-gradient(135deg,#3b82f6,#8b5cf6); -webkit-background-clip:text; -webkit-text-fill-color:transparent;">
        Share. Earn.
      </span>
    </h1>

    <p class="text-slate-400 text-lg font-light max-w-md mx-auto">
      Transform any link into a monetized short URL. Every click counts.
    </p>
  </div>

  <!-- Main card -->
  <div class="w-full max-w-lg fade-up-delay">
    <div class="glass rounded-2xl p-6 sm:p-8 shadow-2xl">

      <!-- URL Input form -->
      <div id="inputSection">
        <label class="block text-sm font-medium text-slate-400 mb-2">Paste your long URL</label>
        <div class="flex gap-2">
          <input
            type="url"
            id="urlInput"
            placeholder="https://example.com/very-long-link..."
            class="input-dark flex-1 rounded-xl px-4 py-3 text-sm"
          />
          <button
            id="generateBtn"
            onclick="generateLink()"
            class="btn-primary text-white font-semibold px-5 py-3 rounded-xl text-sm whitespace-nowrap flex items-center gap-2">
            <span id="btnText">Shorten</span>
            <span id="btnSpinner" class="hidden">
              <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
              </svg>
            </span>
          </button>
        </div>
        <p id="inputError" class="text-red-400 text-xs mt-2 hidden"></p>
      </div>

      <!-- Result section (hidden until link created) -->
      <div id="resultSection" class="hidden mt-5 pt-5 border-t border-white/5">
        <p class="text-xs font-medium text-slate-500 mb-2 uppercase tracking-wider">Your short link</p>
        <div class="flex items-center gap-2">
          <div class="flex-1 input-dark rounded-xl px-4 py-3 text-sm font-medium text-blue-300 truncate" id="shortUrlDisplay"></div>
          <button
            onclick="copyLink()"
            id="copyBtn"
            class="copy-btn btn-primary text-white font-medium px-4 py-3 rounded-xl text-sm flex items-center gap-2 whitespace-nowrap">
            <i data-lucide="copy" class="w-4 h-4"></i>
            <span id="copyBtnText">Copy</span>
          </button>
        </div>

        <% if (!userId) { %>
        <div class="mt-4 p-3 rounded-xl bg-amber-500/10 border border-amber-500/20">
          <p class="text-xs text-amber-300 flex items-start gap-2">
            <i data-lucide="info" class="w-3.5 h-3.5 mt-0.5 flex-shrink-0"></i>
            <span>
              <a href="/signup" class="underline underline-offset-2 font-semibold">Create a free account</a>
              to track clicks and manage all your links in your dashboard.
            </span>
          </p>
        </div>
        <% } %>

        <button
          onclick="resetForm()"
          class="mt-3 w-full text-sm text-slate-500 hover:text-slate-300 transition-colors py-2">
          ← Shorten another link
        </button>
      </div>

    </div>
  </div>

  <!-- Feature pills -->
  <div class="flex flex-wrap justify-center gap-3 mt-8 fade-up-delay-2">
    <% [
      ['zap', 'Instant shortening'],
      ['bar-chart-2', 'Click analytics'],
      ['shield', 'Secure links'],
      ['globe', 'Works globally'],
    ].forEach(([icon, label]) => { %>
      <div class="flex items-center gap-2 px-3 py-1.5 rounded-full text-xs text-slate-500
                  border border-slate-800 bg-slate-900/60">
        <i data-lucide="<%= icon %>" class="w-3 h-3"></i>
        <%= label %>
      </div>
    <% }) %>
  </div>

</main>

<%- include('partials/footer') %>

<script>
let currentShortUrl = '';

async function generateLink() {
  const input = document.getElementById('urlInput');
  const btn   = document.getElementById('generateBtn');
  const errEl = document.getElementById('inputError');
  const url   = input.value.trim();

  errEl.classList.add('hidden');

  if (!url) {
    showError('Please enter a URL.');
    return;
  }

  // Client-side URL check
  try { new URL(url); } catch {
    showError('Please enter a valid URL starting with http:// or https://');
    return;
  }

  // Loading state
  btn.disabled = true;
  document.getElementById('btnText').textContent = 'Shortening';
  document.getElementById('btnSpinner').classList.remove('hidden');

  try {
    const res  = await fetch('/api/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url })
    });
    const data = await res.json();

    if (!res.ok || data.error) {
      showError(data.error || 'Something went wrong.');
      return;
    }

    currentShortUrl = data.shortUrl;
    document.getElementById('shortUrlDisplay').textContent = data.shortUrl;
    document.getElementById('inputSection').classList.add('hidden');
    document.getElementById('resultSection').classList.remove('hidden');
    lucide.createIcons();
  } catch (e) {
    showError('Network error. Please try again.');
  } finally {
    btn.disabled = false;
    document.getElementById('btnText').textContent = 'Shorten';
    document.getElementById('btnSpinner').classList.add('hidden');
  }
}

function showError(msg) {
  const el = document.getElementById('inputError');
  el.textContent = msg;
  el.classList.remove('hidden');
}

async function copyLink() {
  if (!currentShortUrl) return;
  try {
    await navigator.clipboard.writeText(currentShortUrl);
    const btn = document.getElementById('copyBtnText');
    btn.textContent = 'Copied!';
    setTimeout(() => btn.textContent = 'Copy', 2000);
  } catch {
    // Fallback
    const ta = document.createElement('textarea');
    ta.value = currentShortUrl;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
  }
}

function resetForm() {
  document.getElementById('urlInput').value = '';
  document.getElementById('inputSection').classList.remove('hidden');
  document.getElementById('resultSection').classList.add('hidden');
  document.getElementById('inputError').classList.add('hidden');
  currentShortUrl = '';
}

// Allow Enter key to trigger generate
document.getElementById('urlInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') generateLink();
});
</script>
