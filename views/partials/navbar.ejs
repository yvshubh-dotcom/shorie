<header class="lg:ml-64 sticky top-0 z-20 glass border-b border-white/5">
  <div class="flex items-center justify-between px-4 sm:px-6 h-14">
    <!-- Mobile hamburger -->
    <button onclick="openSidebar()" class="lg:hidden p-2 text-gray-400 hover:text-white rounded-lg hover:bg-white/5 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <!-- Page title -->
    <div class="lg:flex-1">
      <h1 class="text-sm font-semibold text-gray-300 lg:text-base"><%= typeof pageTitle !== 'undefined' ? pageTitle : title %></h1>
    </div>

    <!-- Right -->
    <div class="flex items-center gap-3">
      <a href="/links/create" class="hidden sm:flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white text-xs font-semibold px-4 py-2 rounded-lg transition-colors">
        <span>+</span> New Link
      </a>
      <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center text-sm font-bold">
        <%= user.username.charAt(0).toUpperCase() %>
      </div>
    </div>
  </div>
</header>
