<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Google Fonts: Syne (display) + DM Sans (body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            body:    ['DM Sans', 'sans-serif'],
          },
          colors: {
            slate: {
              950: '#0a0f1e',
            }
          }
        }
      }
    }
  </script>

  <style>
    * { font-family: 'DM Sans', sans-serif; }
    h1, h2, h3, .font-display { font-family: 'Syne', sans-serif; }

    body {
      background: #080d1a;
      background-image:
        radial-gradient(ellipse 80% 50% at 50% -20%, rgba(59,130,246,0.15), transparent),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(139,92,246,0.1), transparent);
      min-height: 100vh;
    }

    /* Glassmorphism card */
    .glass {
      background: rgba(15, 23, 42, 0.7);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(148, 163, 184, 0.1);
    }

    /* Gradient button */
    .btn-primary {
      background: linear-gradient(135deg, #3b82f6, #8b5cf6);
      transition: all 0.2s ease;
    }
    .btn-primary:hover:not(:disabled) {
      background: linear-gradient(135deg, #2563eb, #7c3aed);
      transform: translateY(-1px);
      box-shadow: 0 8px 25px rgba(139,92,246,0.35);
    }
    .btn-primary:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      transform: none;
    }

    /* Input fields */
    .input-dark {
      background: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(148, 163, 184, 0.15);
      color: #e2e8f0;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .input-dark:focus {
      outline: none;
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
    }
    .input-dark::placeholder { color: #475569; }

    /* Progress bar */
    .progress-track {
      background: rgba(148,163,184,0.1);
      border-radius: 99px;
      overflow: hidden;
    }
    .progress-fill {
      background: linear-gradient(90deg, #3b82f6, #8b5cf6);
      border-radius: 99px;
      transition: width 0.6s cubic-bezier(0.4,0,0.2,1);
    }

    /* Logo glow */
    .logo-glow {
      text-shadow: 0 0 40px rgba(139,92,246,0.5);
    }

    /* Animations */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-up { animation: fadeUp 0.5s ease both; }
    .fade-up-delay { animation: fadeUp 0.5s 0.1s ease both; }
    .fade-up-delay-2 { animation: fadeUp 0.5s 0.2s ease both; }

    @keyframes pulseRing {
      0%   { transform: scale(1);    opacity: 0.6; }
      100% { transform: scale(1.4);  opacity: 0; }
    }

    /* Timer ring */
    .timer-ring {
      animation: pulseRing 1.5s ease-out infinite;
    }

    /* Shine effect on copy button */
    .copy-btn::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
      transform: translateX(-100%);
      transition: transform 0.4s;
    }
    .copy-btn:hover::after { transform: translateX(100%); }
    .copy-btn { position: relative; overflow: hidden; }

    /* Table rows */
    .table-row { transition: background 0.15s; }
    .table-row:hover { background: rgba(59,130,246,0.05); }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 99px; }
  </style>
</head>
<body class="text-slate-200 antialiased">
