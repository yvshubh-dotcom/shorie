<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="min-h-screen flex items-center justify-center px-4 pt-16 pb-16">
  <div class="w-full max-w-sm fade-up">

    <!-- Progress header -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Step 2 of 3</span>
        <span class="text-xs font-medium text-purple-400">66%</span>
      </div>
      <div class="progress-track h-1.5">
        <div class="progress-fill h-full" style="width: 66%"></div>
      </div>
    </div>

    <!-- Card -->
    <div class="glass rounded-2xl p-7 shadow-2xl text-center">

      <!-- Icon + heading -->
      <div class="mb-6">
        <div class="inline-flex w-14 h-14 rounded-2xl items-center justify-center mb-4"
             style="background: rgba(139,92,246,0.15);">
          <i data-lucide="star" class="w-6 h-6 text-purple-400"></i>
        </div>
        <h1 class="font-display text-xl font-bold text-white mb-2">Great progress!</h1>
        <p class="text-slate-400 text-sm leading-relaxed">
          You're two-thirds of the way there. One more step after this.
        </p>
      </div>

      <!-- Info box -->
      <div class="rounded-xl p-4 mb-6 text-left"
           style="background: rgba(139,92,246,0.08); border: 1px solid rgba(139,92,246,0.2);">
        <div class="flex items-start gap-3">
          <i data-lucide="info" class="w-4 h-4 text-purple-400 mt-0.5 flex-shrink-0"></i>
          <div>
            <p class="text-sm font-medium text-purple-300 mb-1">Why these steps?</p>
            <p class="text-xs text-slate-500 leading-relaxed">
              These steps help the link creator earn a small reward for sharing content with you.
              It only takes a few seconds.
            </p>
          </div>
        </div>
      </div>

      <!-- Step info pills -->
      <div class="flex justify-center gap-2 mb-6">
        <span class="px-2.5 py-1 rounded-full text-xs bg-blue-500/15 text-blue-400 border border-blue-500/20 flex items-center gap-1">
          <i data-lucide="check" class="w-3 h-3"></i>
          Step 1
        </span>
        <span class="px-2.5 py-1 rounded-full text-xs bg-purple-500/20 text-purple-300 border border-purple-500/20">
          Step 2: Here
        </span>
        <span class="px-2.5 py-1 rounded-full text-xs bg-slate-800 text-slate-500">
          Step 3: Last
        </span>
      </div>

      <!-- Continue form -->
      <form action="/l/<%= slug %>/step2" method="POST">
        <button type="submit"
                class="btn-primary w-full py-3 rounded-xl text-white font-semibold text-sm tracking-wide flex items-center justify-center gap-2">
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
          Continue to Step 3
        </button>
      </form>

    </div>

    <p class="text-center text-slate-600 text-xs mt-5 flex items-center justify-center gap-1.5">
      <i data-lucide="shield-check" class="w-3 h-3"></i>
      Link verified by Shortie — safe to proceed
    </p>

  </div>
</main>

<%- include('../partials/footer') %>
