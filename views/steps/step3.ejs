<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="min-h-screen flex items-center justify-center px-4 pt-16 pb-16">
  <div class="w-full max-w-sm fade-up">

    <!-- Progress header -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Step 3 of 3</span>
        <span class="text-xs font-medium text-green-400">99%</span>
      </div>
      <div class="progress-track h-1.5">
        <div class="progress-fill h-full" style="width: 99%"></div>
      </div>
    </div>

    <!-- Card -->
    <div class="glass rounded-2xl p-7 shadow-2xl text-center">

      <!-- Icon + heading -->
      <div class="mb-6">
        <div class="inline-flex w-14 h-14 rounded-2xl items-center justify-center mb-4 relative"
             style="background: rgba(34,197,94,0.15);">
          <i data-lucide="shield-check" class="w-6 h-6 text-green-400"></i>
        </div>
        <h1 class="font-display text-xl font-bold text-white mb-2">Final step!</h1>
        <p class="text-slate-400 text-sm leading-relaxed">
          Confirm you're human to proceed to your destination.
        </p>
      </div>

      <!-- Step info pills -->
      <div class="flex justify-center gap-2 mb-7">
        <span class="px-2.5 py-1 rounded-full text-xs bg-blue-500/15 text-blue-400 border border-blue-500/20 flex items-center gap-1">
          <i data-lucide="check" class="w-3 h-3"></i>
          Step 1
        </span>
        <span class="px-2.5 py-1 rounded-full text-xs bg-purple-500/15 text-purple-400 border border-purple-500/20 flex items-center gap-1">
          <i data-lucide="check" class="w-3 h-3"></i>
          Step 2
        </span>
        <span class="px-2.5 py-1 rounded-full text-xs bg-green-500/20 text-green-300 border border-green-500/20">
          Step 3: Final
        </span>
      </div>

      <!-- Human verification form -->
      <form action="/l/<%= slug %>/step3" method="POST" id="step3form">

        <!-- Checkbox -->
        <label for="humanCheck"
               class="flex items-center gap-3 p-4 rounded-xl cursor-pointer mb-5 text-left
                      border border-slate-700/60 hover:border-slate-600 transition-colors
                      hover:bg-white/[0.02]"
               id="checkLabel">
          <div class="relative flex-shrink-0">
            <input
              type="checkbox"
              id="humanCheck"
              name="human"
              onchange="toggleSubmit(this)"
              class="sr-only"
            />
            <!-- Custom checkbox -->
            <div id="checkBox"
                 class="w-5 h-5 rounded-md border-2 border-slate-600 flex items-center justify-center
                        transition-all duration-200">
              <i data-lucide="check" class="w-3 h-3 text-white hidden" id="checkIcon"></i>
            </div>
          </div>
          <div>
            <p class="text-sm font-medium text-slate-200">I am not a robot</p>
            <p class="text-xs text-slate-500 mt-0.5">Confirm to unlock the destination link</p>
          </div>
        </label>

        <!-- Submit -->
        <button type="submit"
                id="submitBtn"
                disabled
                class="btn-primary w-full py-3.5 rounded-xl text-white font-semibold text-sm tracking-wide
                       flex items-center justify-center gap-2">
          <i data-lucide="external-link" class="w-4 h-4"></i>
          <span>Go to Destination</span>
        </button>

      </form>

      <!-- Countdown redirect note -->
      <div id="redirectNote" class="hidden mt-4">
        <p class="text-xs text-green-400 flex items-center justify-center gap-1.5">
          <i data-lucide="loader" class="w-3 h-3 animate-spin"></i>
          Redirecting in <span id="redirectCount">3</span>s...
        </p>
      </div>

    </div>

    <p class="text-center text-slate-600 text-xs mt-5 flex items-center justify-center gap-1.5">
      <i data-lucide="shield-check" class="w-3 h-3"></i>
      Link verified by Shortie — safe to proceed
    </p>

  </div>
</main>

<%- include('../partials/footer') %>

<script>
function toggleSubmit(checkbox) {
  const btn     = document.getElementById('submitBtn');
  const box     = document.getElementById('checkBox');
  const icon    = document.getElementById('checkIcon');
  const label   = document.getElementById('checkLabel');

  if (checkbox.checked) {
    btn.disabled = false;
    box.classList.remove('border-slate-600');
    box.classList.add('border-blue-500');
    box.style.background = 'linear-gradient(135deg, #3b82f6, #8b5cf6)';
    icon.classList.remove('hidden');
    label.style.borderColor = 'rgba(59,130,246,0.4)';
    label.style.background  = 'rgba(59,130,246,0.05)';
  } else {
    btn.disabled = true;
    box.classList.add('border-slate-600');
    box.classList.remove('border-blue-500');
    box.style.background = '';
    icon.classList.add('hidden');
    label.style.borderColor = '';
    label.style.background  = '';
  }
  lucide.createIcons();
}

// On form submit: show countdown
document.getElementById('step3form').addEventListener('submit', function() {
  document.getElementById('redirectNote').classList.remove('hidden');
  document.getElementById('submitBtn').disabled = true;
  let c = 3;
  const el = document.getElementById('redirectCount');
  const t  = setInterval(() => {
    c--;
    if (el) el.textContent = c;
    if (c <= 0) clearInterval(t);
  }, 1000);
});
</script>
