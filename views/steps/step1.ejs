<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<main class="min-h-screen flex items-center justify-center px-4 pt-16 pb-16">
  <div class="w-full max-w-sm fade-up">

    <!-- Progress header -->
    <div class="mb-6">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-medium text-slate-500 uppercase tracking-wider">Step 1 of 3</span>
        <span class="text-xs font-medium text-blue-400">33%</span>
      </div>
      <div class="progress-track h-1.5">
        <div class="progress-fill h-full" style="width: 33%"></div>
      </div>
    </div>

    <!-- Card -->
    <div class="glass rounded-2xl p-7 shadow-2xl text-center">

      <!-- Icon + heading -->
      <div class="mb-6">
        <div class="inline-flex w-14 h-14 rounded-2xl items-center justify-center mb-4 relative"
             style="background: rgba(59,130,246,0.15);">
          <i data-lucide="clock" class="w-6 h-6 text-blue-400"></i>
          <!-- Pulsing ring -->
          <div class="absolute inset-0 rounded-2xl border border-blue-400/30 timer-ring"></div>
        </div>
        <h1 class="font-display text-xl font-bold text-white mb-2">Almost there!</h1>
        <p class="text-slate-400 text-sm leading-relaxed">
          Please wait a moment while we prepare your destination link.
        </p>
      </div>

      <!-- Timer display -->
      <div class="mb-6">
        <div class="inline-flex flex-col items-center justify-center w-20 h-20 rounded-full
                    border-2 border-slate-700 mb-3 relative">
          <span id="timerCount" class="font-display text-3xl font-bold text-white">5</span>
          <span class="text-slate-500 text-xs">secs</span>
          <!-- SVG progress ring -->
          <svg class="absolute inset-0 w-20 h-20 -rotate-90" viewBox="0 0 80 80">
            <circle cx="40" cy="40" r="36" fill="none" stroke="rgba(148,163,184,0.1)" stroke-width="3"/>
            <circle id="timerRing" cx="40" cy="40" r="36" fill="none"
                    stroke="url(#timerGrad)" stroke-width="3"
                    stroke-linecap="round"
                    stroke-dasharray="226.2"
                    stroke-dashoffset="0"/>
            <defs>
              <linearGradient id="timerGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" style="stop-color:#3b82f6"/>
                <stop offset="100%" style="stop-color:#8b5cf6"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <p class="text-slate-500 text-xs">
          Button enables when timer reaches 0
        </p>
      </div>

      <!-- Step info pills -->
      <div class="flex justify-center gap-2 mb-6">
        <span class="px-2.5 py-1 rounded-full text-xs bg-blue-500/20 text-blue-300 border border-blue-500/20">
          Step 1: Wait
        </span>
        <span class="px-2.5 py-1 rounded-full text-xs bg-slate-800 text-slate-500">
          Step 2: Verify
        </span>
        <span class="px-2.5 py-1 rounded-full text-xs bg-slate-800 text-slate-500">
          Step 3: Confirm
        </span>
      </div>

      <!-- Continue form -->
      <form action="/l/<%= slug %>/step1" method="POST">
        <button type="submit"
                id="continueBtn"
                disabled
                class="btn-primary w-full py-3 rounded-xl text-white font-semibold text-sm tracking-wide flex items-center justify-center gap-2">
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
          <span id="btnLabel">Please wait... (5s)</span>
        </button>
      </form>

    </div>

    <!-- Safety note -->
    <p class="text-center text-slate-600 text-xs mt-5 flex items-center justify-center gap-1.5">
      <i data-lucide="shield-check" class="w-3 h-3"></i>
      Link verified by Shortie — safe to proceed
    </p>

  </div>
</main>

<%- include('../partials/footer') %>

<script>
(function() {
  const btn    = document.getElementById('continueBtn');
  const label  = document.getElementById('btnLabel');
  const count  = document.getElementById('timerCount');
  const ring   = document.getElementById('timerRing');
  const total  = 226.2; // circumference of r=36
  let seconds  = 5;

  const interval = setInterval(() => {
    seconds--;
    count.textContent  = seconds;
    label.textContent  = seconds > 0 ? `Please wait... (${seconds}s)` : 'Continue →';

    // Update SVG ring offset (drain as time passes)
    const progress = seconds / 5;
    ring.style.strokeDashoffset = total * progress;

    if (seconds <= 0) {
      clearInterval(interval);
      btn.disabled = false;
      label.textContent = 'Continue →';
      count.textContent = '✓';
      count.style.fontSize = '1rem';
    }
  }, 1000);
})();
</script>
