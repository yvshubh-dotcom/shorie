<%- include('../partials/header') %>
<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>
  <div class="flex-1 lg:ml-64 flex flex-col min-h-screen">
    <%- include('../partials/navbar') %>

    <main class="flex-1 p-4 sm:p-6 animate-fade-up">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-xl font-bold mb-6">Create Short Link</h2>

        <% if (error) { %>
        <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-xl px-4 py-3 mb-6 flex items-center gap-2">
          <span>✕</span> <%= error %>
        </div>
        <% } %>

        <% if (success && newLink) { %>
        <div class="glass rounded-2xl p-6 mb-6 border border-brand-500/30 bg-brand-500/5">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-brand-400 text-lg">✓</span>
            <span class="text-brand-400 font-semibold text-sm">Link created successfully!</span>
          </div>
          <p class="text-xs text-gray-500 mb-2">Your short link:</p>
          <div class="flex items-center gap-3 glass rounded-xl px-4 py-3">
            <span class="font-mono text-brand-300 text-sm flex-1 truncate" id="short-url"><%= newLink.shortUrl %></span>
            <button onclick="copyToClipboard('<%= newLink.shortUrl %>', this)" class="text-xs text-gray-400 hover:text-brand-400 transition-colors flex-shrink-0 font-medium">
              Copy
            </button>
          </div>
        </div>
        <% } %>

        <div class="glass card-glow rounded-2xl p-6 sm:p-8">
          <form action="/links/create" method="POST" class="space-y-5">
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Destination URL <span class="text-red-400">*</span></label>
              <input type="text" name="originalUrl" required
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-gray-600 focus:outline-none focus:border-brand-500/60 focus:ring-1 focus:ring-brand-500/30 transition-all"
                placeholder="https://example.com/your-long-url"/>
              <p class="text-xs text-gray-600 mt-1">Enter the full URL you want to shorten and monetize</p>
            </div>

            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Link Title <span class="text-gray-600">(optional)</span></label>
              <input type="text" name="title"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-gray-600 focus:outline-none focus:border-brand-500/60 focus:ring-1 focus:ring-brand-500/30 transition-all"
                placeholder="My awesome link"/>
            </div>

            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Custom Code <span class="text-gray-600">(optional)</span></label>
              <div class="flex items-center glass border border-white/10 rounded-xl overflow-hidden focus-within:border-brand-500/60 focus-within:ring-1 focus-within:ring-brand-500/30 transition-all">
                <span class="px-4 py-3 text-xs text-gray-600 border-r border-white/10 flex-shrink-0 font-mono">/r/</span>
                <input type="text" name="customCode" minlength="3" maxlength="20" pattern="[a-zA-Z0-9_-]+"
                  class="flex-1 bg-transparent px-4 py-3 text-sm placeholder-gray-600 focus:outline-none"
                  placeholder="my-custom-code"/>
              </div>
              <p class="text-xs text-gray-600 mt-1">3–20 characters. Letters, numbers, hyphens, underscores. Leave blank for auto-generated.</p>
            </div>

            <button type="submit"
              class="w-full bg-brand-500 hover:bg-brand-400 text-white font-semibold py-3.5 rounded-xl transition-all hover:scale-[1.01] active:scale-[0.99] shadow-lg shadow-brand-500/20">
              Create Short Link →
            </button>
          </form>
        </div>

        <!-- Info cards -->
        <div class="grid grid-cols-2 gap-4 mt-6">
          <div class="glass rounded-xl p-4">
            <p class="text-xs text-gray-500 mb-1">CPM Rate</p>
            <p class="font-bold gradient-text">$<%= (user.cpmRate || 2).toFixed(2) %>/1K</p>
          </div>
          <div class="glass rounded-xl p-4">
            <p class="text-xs text-gray-500 mb-1">Your Balance</p>
            <p class="font-bold gradient-text">$<%= (user.balance || 0).toFixed(4) %></p>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
<%- include('../partials/footer') %>
