<%- include('../partials/header') %>
<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>
  <div class="flex-1 lg:ml-64 flex flex-col min-h-screen">
    <%- include('../partials/navbar') %>

    <main class="flex-1 p-4 sm:p-6 animate-fade-up">
      <div class="max-w-lg mx-auto">
        <div class="flex items-center gap-3 mb-6">
          <a href="/earnings" class="text-gray-500 hover:text-white text-sm">← Back</a>
          <h2 class="text-xl font-bold">Request Withdrawal</h2>
        </div>

        <% if (error) { %>
        <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-xl px-4 py-3 mb-6 flex items-center gap-2">
          <span>✕</span> <%= error %>
        </div>
        <% } %>
        <% if (success) { %>
        <div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-xl px-4 py-3 mb-6 flex items-center gap-2">
          <span>✓</span> <%= success %>
        </div>
        <% } %>

        <!-- Balance card -->
        <div class="glass rounded-2xl p-5 mb-6 flex items-center justify-between">
          <div>
            <p class="text-xs text-gray-500">Available Balance</p>
            <p class="text-3xl font-bold gradient-text mt-1">$<%= (user.balance || 0).toFixed(4) %></p>
          </div>
          <div class="text-right">
            <p class="text-xs text-gray-500">Minimum</p>
            <p class="text-lg font-semibold text-gray-300">$<%= minWithdraw.toFixed(2) %></p>
          </div>
        </div>

        <div class="glass card-glow rounded-2xl p-6 sm:p-8">
          <form action="/earnings/withdraw" method="POST" class="space-y-5">
            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5">Amount (USD)</label>
              <input type="number" name="amount" min="<%= minWithdraw %>" max="<%= user.balance %>" step="0.01" required
                value="<%= (user.balance || 0).toFixed(2) %>"
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-gray-600 focus:outline-none focus:border-brand-500/60 focus:ring-1 focus:ring-brand-500/30 transition-all"/>
              <p class="text-xs text-gray-600 mt-1">Min: $<%= minWithdraw.toFixed(2) %> · Max: $<%= (user.balance || 0).toFixed(2) %></p>
            </div>

            <div>
              <label class="block text-xs font-medium text-gray-400 mb-2">Payment Method</label>
              <div class="grid grid-cols-3 gap-3" id="method-selector">
                <% [['upi','₹','UPI'], ['paypal','P','PayPal'], ['binance','B','Binance']].forEach(([val, icon, label]) => { %>
                <label class="cursor-pointer">
                  <input type="radio" name="paymentMethod" value="<%= val %>" class="hidden peer" <%= val === 'upi' ? 'checked' : '' %>>
                  <div class="glass peer-checked:border-brand-500/60 peer-checked:bg-brand-500/10 border border-white/10 rounded-xl p-3 text-center transition-all hover:border-white/20">
                    <p class="text-xl font-bold mb-1 gradient-text"><%= icon %></p>
                    <p class="text-xs text-gray-400"><%= label %></p>
                  </div>
                </label>
                <% }) %>
              </div>
            </div>

            <div>
              <label class="block text-xs font-medium text-gray-400 mb-1.5" id="payment-label">UPI ID / Payment Address</label>
              <input type="text" name="paymentDetails" required
                class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm placeholder-gray-600 focus:outline-none focus:border-brand-500/60 focus:ring-1 focus:ring-brand-500/30 transition-all"
                placeholder="Enter your payment details" id="payment-input"/>
            </div>

            <% if (user.balance < minWithdraw) { %>
            <div class="bg-yellow-500/10 border border-yellow-500/30 text-yellow-400 text-sm rounded-xl px-4 py-3">
              Your balance is below the minimum withdrawal amount of $<%= minWithdraw.toFixed(2) %>.
            </div>
            <button type="button" disabled class="w-full bg-gray-700 text-gray-500 font-semibold py-3.5 rounded-xl cursor-not-allowed">
              Insufficient Balance
            </button>
            <% } else { %>
            <button type="submit"
              class="w-full bg-brand-500 hover:bg-brand-400 text-white font-semibold py-3.5 rounded-xl transition-all hover:scale-[1.01] shadow-lg shadow-brand-500/20">
              Submit Withdrawal Request →
            </button>
            <% } %>
          </form>
        </div>

        <div class="mt-4 glass rounded-xl px-5 py-4 text-xs text-gray-500 space-y-1">
          <p>• Withdrawals are processed within 24–72 hours</p>
          <p>• Only one pending withdrawal allowed at a time</p>
          <p>• Minimum withdrawal: $<%= minWithdraw.toFixed(2) %></p>
        </div>
      </div>
    </main>
  </div>
</div>
<script>
const labels = { upi: 'UPI ID (e.g. name@upi)', paypal: 'PayPal Email Address', binance: 'Binance UID or Email' };
const placeholders = { upi: 'yourname@paytm', paypal: 'paypal@email.com', binance: '123456789' };
document.querySelectorAll('input[name="paymentMethod"]').forEach(r => {
  r.addEventListener('change', () => {
    document.getElementById('payment-label').textContent = labels[r.value];
    document.getElementById('payment-input').placeholder = placeholders[r.value];
  });
});
</script>
<%- include('../partials/footer') %>
