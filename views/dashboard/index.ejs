<%- include('../partials/header') %>
<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>

  <div class="flex-1 lg:ml-64 flex flex-col min-h-screen">
    <%- include('../partials/navbar') %>

    <main class="flex-1 p-4 sm:p-6 space-y-6 animate-fade-up">
      <!-- Welcome -->
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-xl font-bold">Good day, <span class="gradient-text"><%= user.username %></span> 👋</h2>
          <p class="text-sm text-gray-500 mt-0.5">Here's your earnings overview</p>
        </div>
        <a href="/links/create" class="hidden sm:flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-all hover:scale-105">
          + New Link
        </a>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <%
          const cards = [
            { label: 'Total Earnings', value: '$' + (user.totalEarnings || 0).toFixed(4), icon: '◎', color: 'from-brand-500/20 to-brand-600/10', textColor: 'text-brand-400' },
            { label: 'Available Balance', value: '$' + (user.balance || 0).toFixed(4), icon: '↑', color: 'from-blue-500/20 to-blue-600/10', textColor: 'text-blue-400' },
            { label: 'Total Clicks', value: (user.totalClicks || 0).toLocaleString(), icon: '↗', color: 'from-purple-500/20 to-purple-600/10', textColor: 'text-purple-400' },
            { label: 'Total Links', value: totalLinks.toString(), icon: '⛓', color: 'from-orange-500/20 to-orange-600/10', textColor: 'text-orange-400' },
          ];
        %>
        <% cards.forEach(card => { %>
        <div class="glass card-glow rounded-2xl p-5 bg-gradient-to-br <%= card.color %> border border-white/5 hover:border-white/10 transition-all">
          <div class="flex items-start justify-between mb-3">
            <span class="text-xl <%= card.textColor %>"><%= card.icon %></span>
          </div>
          <p class="text-2xl font-bold text-white mb-1"><%= card.value %></p>
          <p class="text-xs text-gray-500"><%= card.label %></p>
        </div>
        <% }) %>
      </div>

      <!-- CPM Info -->
      <div class="glass rounded-2xl p-5 flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-brand-500/10 flex items-center justify-center text-brand-400 text-lg">$</div>
          <div>
            <p class="text-sm font-semibold">Current CPM Rate</p>
            <p class="text-xs text-gray-500">Earnings per 1,000 clicks</p>
          </div>
        </div>
        <div class="sm:ml-auto">
          <span class="text-2xl font-bold gradient-text">$<%= cpmRate.toFixed(2) %></span>
          <span class="text-gray-500 text-sm"> / 1K clicks</span>
        </div>
      </div>

      <!-- Recent Links -->
      <div class="glass rounded-2xl overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-white/5">
          <h3 class="font-semibold text-sm">Recent Links</h3>
          <a href="/links" class="text-xs text-brand-400 hover:text-brand-300">View all →</a>
        </div>
        <% if (links.length === 0) { %>
        <div class="text-center py-12 text-gray-600">
          <p class="text-4xl mb-3">⛓</p>
          <p class="text-sm">No links yet. <a href="/links/create" class="text-brand-400">Create your first link</a></p>
        </div>
        <% } else { %>
        <div class="divide-y divide-white/5">
          <% links.forEach(link => { %>
          <div class="flex items-center gap-4 px-5 py-4 hover:bg-white/2 transition-colors">
            <div class="w-8 h-8 rounded-lg bg-brand-500/10 flex items-center justify-center text-brand-400 text-sm flex-shrink-0">⛓</div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium text-white truncate"><%= link.shortCode %></p>
              <p class="text-xs text-gray-600 truncate"><%= link.originalUrl %></p>
            </div>
            <div class="text-right flex-shrink-0">
              <p class="text-sm font-semibold"><%= link.clicks %> <span class="text-gray-600 font-normal text-xs">clicks</span></p>
              <p class="text-xs text-brand-400">$<%= link.earnings.toFixed(4) %></p>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Recent Withdrawals -->
      <% if (withdrawals.length > 0) { %>
      <div class="glass rounded-2xl overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-white/5">
          <h3 class="font-semibold text-sm">Recent Withdrawals</h3>
          <a href="/earnings" class="text-xs text-brand-400 hover:text-brand-300">View all →</a>
        </div>
        <div class="divide-y divide-white/5">
          <% withdrawals.forEach(w => { %>
          <div class="flex items-center gap-4 px-5 py-4">
            <div class="min-w-0 flex-1">
              <p class="text-sm font-medium">$<%= w.amount.toFixed(2) %> via <%= w.paymentMethod.toUpperCase() %></p>
              <p class="text-xs text-gray-600"><%= new Date(w.createdAt).toLocaleDateString() %></p>
            </div>
            <span class="text-xs px-2.5 py-1 rounded-full font-medium
              <%= w.status === 'approved' ? 'bg-green-500/10 text-green-400' : w.status === 'rejected' ? 'bg-red-500/10 text-red-400' : 'bg-yellow-500/10 text-yellow-400' %>">
              <%= w.status %>
            </span>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </main>
  </div>
</div>
<%- include('../partials/footer') %>
