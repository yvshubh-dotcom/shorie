<%- include('../partials/header') %>
<div class="flex min-h-screen">
  <%- include('../partials/sidebar') %>
  <div class="flex-1 lg:ml-64 flex flex-col min-h-screen">
    <%- include('../partials/navbar') %>

    <main class="flex-1 p-4 sm:p-6 animate-fade-up space-y-6">
      <h2 class="text-xl font-bold">Earnings & Payments</h2>

      <% if (success) { %>
      <div class="bg-green-500/10 border border-green-500/30 text-green-400 text-sm rounded-xl px-4 py-3 flex items-center gap-2">
        <span>✓</span> <%= success %>
      </div>
      <% } %>
      <% if (error) { %>
      <div class="bg-red-500/10 border border-red-500/30 text-red-400 text-sm rounded-xl px-4 py-3 flex items-center gap-2">
        <span>✕</span> <%= error %>
      </div>
      <% } %>

      <!-- Cards -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="glass rounded-2xl p-5">
          <p class="text-xs text-gray-500 mb-2">Total Earnings</p>
          <p class="text-2xl font-bold gradient-text">$<%= (user.totalEarnings || 0).toFixed(4) %></p>
        </div>
        <div class="glass rounded-2xl p-5">
          <p class="text-xs text-gray-500 mb-2">Available</p>
          <p class="text-2xl font-bold text-blue-400">$<%= (user.balance || 0).toFixed(4) %></p>
        </div>
        <div class="glass rounded-2xl p-5">
          <p class="text-xs text-gray-500 mb-2">Pending</p>
          <p class="text-2xl font-bold text-yellow-400">$<%= pendingAmount.toFixed(4) %></p>
        </div>
        <div class="glass rounded-2xl p-5">
          <p class="text-xs text-gray-500 mb-2">Paid Out</p>
          <p class="text-2xl font-bold text-purple-400">$<%= totalWithdrawn.toFixed(2) %></p>
        </div>
      </div>

      <!-- Withdraw CTA -->
      <div class="glass rounded-2xl p-5 flex flex-col sm:flex-row items-center gap-4">
        <div class="flex-1">
          <p class="font-semibold mb-1">Ready to cash out?</p>
          <p class="text-sm text-gray-500">Minimum withdrawal: <span class="text-white font-medium">$<%= minWithdraw.toFixed(2) %></span></p>
        </div>
        <% if (user.balance >= minWithdraw) { %>
        <a href="/earnings/withdraw" class="bg-brand-500 hover:bg-brand-400 text-white font-semibold px-6 py-3 rounded-xl transition-all hover:scale-105 text-sm">
          Withdraw Now →
        </a>
        <% } else { %>
        <div class="text-right">
          <p class="text-sm text-gray-500">Need <span class="text-white">$<%= (minWithdraw - user.balance).toFixed(4) %></span> more</p>
          <div class="w-48 h-2 bg-white/5 rounded-full mt-2">
            <div class="h-2 rounded-full progress-bar" style="width: <%= Math.min(100, (user.balance / minWithdraw) * 100) %>%"></div>
          </div>
        </div>
        <% } %>
      </div>

      <!-- Withdrawal history -->
      <div class="glass rounded-2xl overflow-hidden">
        <div class="px-5 py-4 border-b border-white/5">
          <h3 class="font-semibold text-sm">Withdrawal History</h3>
        </div>
        <% if (withdrawals.length === 0) { %>
        <div class="text-center py-12 text-gray-600">
          <p class="text-3xl mb-3">↑</p>
          <p class="text-sm">No withdrawals yet</p>
        </div>
        <% } else { %>
        <div class="divide-y divide-white/5">
          <% withdrawals.forEach(w => { %>
          <div class="flex items-center gap-4 px-5 py-4">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center text-sm
              <%= w.paymentMethod === 'upi' ? 'bg-purple-500/10 text-purple-400' : w.paymentMethod === 'paypal' ? 'bg-blue-500/10 text-blue-400' : 'bg-yellow-500/10 text-yellow-400' %>">
              <%= w.paymentMethod === 'upi' ? '₹' : w.paymentMethod === 'paypal' ? 'P' : 'B' %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium">$<%= w.amount.toFixed(2) %> via <%= w.paymentMethod.toUpperCase() %></p>
              <p class="text-xs text-gray-600"><%= w.paymentDetails %> · <%= new Date(w.createdAt).toLocaleDateString() %></p>
            </div>
            <span class="text-xs px-2.5 py-1 rounded-full font-medium
              <%= w.status === 'approved' ? 'bg-green-500/10 text-green-400' : w.status === 'rejected' ? 'bg-red-500/10 text-red-400' : 'bg-yellow-500/10 text-yellow-400' %>">
              <%= w.status %>
            </span>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </main>
  </div>
</div>
<%- include('../partials/footer') %>
