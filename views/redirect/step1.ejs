<%- include('../partials/header') %>
<div class="min-h-screen flex flex-col items-center justify-center px-4 relative overflow-hidden">
  <!-- Animated background -->
  <div class="fixed inset-0 pointer-events-none">
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-brand-500/5 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-72 h-72 bg-blue-500/3 rounded-full blur-3xl animate-pulse-slow" style="animation-delay:1s"></div>
  </div>

  <!-- Logo -->
  <div class="absolute top-6 left-6 flex items-center gap-2">
    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center font-bold text-white text-sm">S</div>
    <span class="font-bold gradient-text">Shortie</span>
  </div>

  <div class="w-full max-w-md text-center relative z-10">
    <!-- Ad placeholder -->
    <div class="glass rounded-2xl p-6 mb-8 min-h-28 flex items-center justify-center border border-white/5">
      <div class="text-center">
        <p class="text-xs text-gray-600 mb-2">Advertisement</p>
        <div class="w-full h-20 bg-white/3 rounded-xl flex items-center justify-center">
          <p class="text-gray-700 text-xs">Ad space</p>
        </div>
      </div>
    </div>

    <!-- Timer card -->
    <div class="glass card-glow rounded-3xl p-8">
      <div class="w-16 h-16 rounded-2xl bg-brand-500/10 flex items-center justify-center mx-auto mb-5 text-3xl">⛓</div>
      <h1 class="font-bold text-xl mb-2">Redirecting you shortly</h1>
      <p class="text-gray-500 text-sm mb-8">
        <%= link.title || 'Shortie Link' %>
      </p>

      <!-- Progress bar -->
      <div class="w-full h-1.5 bg-white/10 rounded-full mb-6 overflow-hidden">
        <div id="progress" class="h-full progress-bar rounded-full transition-all ease-linear" style="width:0%"></div>
      </div>

      <!-- Timer display -->
      <div class="text-6xl font-bold font-mono gradient-text mb-6" id="timer">5</div>
      <p class="text-xs text-gray-600 mb-6">Please wait while the page loads</p>

      <!-- Continue button -->
      <form action="/r/<%= shortCode %>/continue" method="POST" id="continue-form">
        <button type="submit" id="continue-btn" disabled
          class="w-full font-bold py-4 rounded-2xl text-sm transition-all
          bg-white/5 text-gray-600 cursor-not-allowed"
          id="continue-btn">
          Please wait... (<span id="btn-timer">5</span>s)
        </button>
      </form>
    </div>

    <p class="text-xs text-gray-700 mt-6">Powered by Shortie</p>
  </div>
</div>

<script>
const DURATION = 5;
let elapsed = 0;
const progress = document.getElementById('progress');
const timerEl = document.getElementById('timer');
const btnTimerEl = document.getElementById('btn-timer');
const btn = document.getElementById('continue-btn');

const interval = setInterval(() => {
  elapsed++;
  const remaining = DURATION - elapsed;
  const pct = (elapsed / DURATION) * 100;

  progress.style.width = pct + '%';
  timerEl.textContent = remaining;
  if (btnTimerEl) btnTimerEl.textContent = remaining;

  if (elapsed >= DURATION) {
    clearInterval(interval);
    btn.disabled = false;
    btn.className = 'w-full font-bold py-4 rounded-2xl text-sm transition-all bg-brand-500 hover:bg-brand-400 text-white shadow-lg shadow-brand-500/25 hover:scale-[1.02] active:scale-[0.98]';
    btn.innerHTML = 'Continue to Destination →';
    timerEl.textContent = '✓';
  }
}, 1000);
</script>
<%- include('../partials/footer') %>
